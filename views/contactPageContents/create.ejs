<div class="action">
    <h1>
        <%= title %>
    </h1>

    <div class="back-btn">
        <a href="/admin/<%= activeRoute %>">Back</a>
    </div>          

    <div class="add-block">
        <form action="/admin/<%= activeRoute %>/add" method="post">
            <label for="lang">Lang<span>*</span></label>
            <select name="lang" id="lang" class="lang-selector" required>
                <option value="" disabled selected>Choose language</option>
                <% langs.forEach(elem=> { %>
                    <option value="<%= elem.code %>">
                        <%= elem.code %>
                    </option>
                    <% }) %>
            </select>

            <label for="title">Title<span>*</span></label>
            <input type="text" name="title" id="title" required>

            <label for="name">Name placeholder<span>*</span></label>
            <input type="text" name="name_placeholder" id="name" required>

            <label for="email">Email placeholder<span>*</span></label>
            <input type="text" name="email_placeholder" id="email" required>

            <label for="mess">Message placeholder<span>*</span></label>
            <input type="text" name="message_placeholder" id="mess" required>

            <label for="btn">Button text<span>*</span></label>
            <input type="text" name="btn_text" id="btn" required>

            <label for="success">Successful text<span>*</span></label>
            <input type="text" name="successful_text" id="success" required>

            <label for="error">Error text<span>*</span></label>
            <input type="text" name="error_text" id="error" required>

            <button type="submit" class="submit">Create</button>
        </form>
    </div>
</div>