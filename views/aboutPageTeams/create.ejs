<div class="action">
    <h1>
        <%= title %>
    </h1>

    <div class="back-btn">
        <a href="/admin/<%= activeRoute %>">Back</a>
    </div>      

    <div class="add-block">
        <form action="/admin/<%= activeRoute %>/add" enctype="multipart/form-data" method="post">
            <label for="lang">Lang<span>*</span></label>
            <select name="lang" id="lang" class="lang-selector" required>
                <option value="" disabled selected hidden>Choose language</option>
                <% langs.forEach(elem=> { %>
                    <option value="<%= elem.code %>">
                        <%= elem.code %>
                    </option>
                    <% }) %>
            </select>

            <label for="name">Name<span>*</span></label>
            <input type="text" name="name" id="name" required>

            <label for="profession">Profession<span>*</span></label>
            <input type="text" name="profession" id="profession" required>

            <label for="img">Image<span>*</span></label>
            <input type="file" accept="image/*" name="image" id="img" required>

            <!-- <input type="image" id="preview" src="" alt="image preview" class="image-preview"> -->
            <img src="" alt="image preview" id="preview" class="image-preview">

            <button type="submit" class="submit">Create</button>
        </form>
    </div>
</div>