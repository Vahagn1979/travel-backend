<div class="auth">
    <div class="heading">
        <h1>Travel Admin Panel</h1>

        <button class="theme-switch">
            <img src="/images/dark_mode.svg" alt="theme-switch images">
        </button>
    </div>

    <div class="content">
        <% if (error) { %>
            <p class="error-text"><%= error %></p>
        <% } %>

        <form action="/admin/login" method="post">
            <div class="form-row">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" required>
            </div>
            <div class="form-row login-password-field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
                <img src="/images/visibility.svg" alt="visible password" class="password-img">
            </div>

            <button type="submit">Login</button>
        </form>
    </div>
</div>